# Telegram API credentials (get from https://my.telegram.org)
API_ID=12345678
API_HASH=your_api_hash_here

# Your Telegram userbot session name
SESSION_NAME=forwarder_session

# String session (for Railway / cloud deployment)
# Generate with: python generate_session.py
# Leave empty to use file-based session instead
SESSION_STRING=

# Target channel (where posts will be forwarded to)
# Use channel username (@channel) or chat ID (-100xxxxxxxxxx)
TARGET_CHANNEL=@your_target_channel

# Owner Telegram user ID (who can control the bot)
# Get your ID from @userinfobot
OWNER_ID=123456789

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
